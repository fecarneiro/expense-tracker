{
  "[typescript]": {
    "editor.defaultFormatter": "biomejs.biome"
  },
  "[javascript]": {
    "editor.defaultFormatter": "biomejs.biome"
  },
  "[json]": {
    "editor.defaultFormatter": "biomejs.biome"
  },
  "[jsonc]": {
    "editor.defaultFormatter": "biomejs.biome"
  },

  "editor.codeActionsOnSave": {
    "source.organizeImports": "never",
    "source.fixAll.biome": "explicit",
    "source.organizeImports.biome": "explicit"
  },

  "biome.requireConfiguration": true,

  // TypeScript 7 (native): requires the "TypeScript (Native Preview)" extension
  // (typescriptteam.native-preview). Points to the workspace package root — not /lib.
  "typescript.experimental.useTsgo": true

  // Fallback for TypeScript 6 (built-in extension): if Native Preview causes issues,
  // comment the setting above and uncomment the line below after pinning typescript@6.
  // "typescript.tsdk": "./node_modules/typescript/lib"
}
