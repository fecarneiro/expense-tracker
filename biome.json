{
  "$schema": "./node_modules/@biomejs/biome/configuration_schema.json",

  "vcs": {
    "enabled": true,
    "clientKind": "git",
    "useIgnoreFile": true
  },

  "files": {
    "ignoreUnknown": false,
    "includes": [
      "apps/**/*.ts",
      "apps/**/*.vue",
      "apps/**/*.css",

      "packages/**/*.ts",

      "*.ts",
      "*.json",
      "*.jsonc",

      ".vscode/**/*.json",

      "!!**/dist",
      "!!**/build",
      "!!**/coverage"
    ]
  },

  "formatter": {
    "enabled": true,
    "formatWithErrors": false,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineEnding": "lf",
    "lineWidth": 100
  },

  "linter": {
    "rules": {
      "preset": "recommended"
    }
  },

  "javascript": {
    "formatter": {
      "quoteStyle": "single",
      "semicolons": "asNeeded"
    }
  },

  "html": {
    "experimentalFullSupportEnabled": true,
    "formatter": {
      "enabled": true
    }
  },

  "css": {
    "formatter": {
      "enabled": true
    }
  },

  "assist": {
    "enabled": true,
    "actions": {
      "source": {
        "organizeImports": "on"
      }
    }
  }
}
